{
  "name": "Spring Boot Kafka Workshop",
  "image": "mcr.microsoft.com/devcontainers/java:25",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": false,
      "enableNonRootDocker": "true",
      "dockerDashComposeVersion": "v2"
    },
    "ghcr.io/devcontainers/features/java:1": {
      "version": "none",
      "jdkDistro": "ms",
      "installMaven": "true",
      "mavenVersion": "latest",
      "installGradle": "false"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-spring-boot-dashboard",
        "vmware.vscode-boot-dev-pack",
        "pivotal.vscode-spring-boot",
        "redhat.java",
        "vscjava.vscode-maven",
        "ms-azuretools.vscode-docker",
        "rangav.vscode-thunder-client",
        "streetsidesoftware.code-spell-checker",
        "eamodio.gitlens"
      ],
      "settings": {
        "files.exclude": {
          "**/.classpath": true,
          "**/.project": true,
          "**/.settings": true,
          "**/.factorypath": true
        },
        "java.compile.nullAnalysis.mode": "automatic",
        "spring-boot.ls.checkjvm": false,
        "java.server.launchMode": "Standard",
        "maven.terminal.useJavaHome": true
      }
    }
  },

  "forwardPorts": [
    8080,
    8081,
    3306,
    9092,
    2181
  ],

  "portsAttributes": {
    "8080": {
      "label": "Frontend (Thymeleaf UI)",
      "onAutoForward": "notify"
    },
    "8081": {
      "label": "Backend (REST API)",
      "onAutoForward": "silent"
    },
    "3306": {
      "label": "MySQL Database",
      "onAutoForward": "silent"
    },
    "9092": {
      "label": "Kafka Broker",
      "onAutoForward": "silent"
    },
    "2181": {
      "label": "Zookeeper",
      "onAutoForward": "silent"
    }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "postStartCommand": "echo 'Welcome to the Spring Boot Kafka Workshop! \n' && cat .devcontainer/welcome.txt",

  "remoteUser": "vscode",

  "containerEnv": {
    "SPRING_PROFILES_ACTIVE": "dev"
  }
}
